# SPA rewrite — any path that isn't a real file/directory falls back to index.html
# so the React router can take over on direct visits / refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → /index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache hashed assets (Vite outputs to /assets/ with content hashes)
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Gzip / Brotli if available
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
